{{- $index := slice -}}
{{- range .Pages -}}
  {{- $authors := slice -}}
  {{- range .Params.authors -}}
    {{- $author := page.GetPage (printf "/authors/%s" .author) -}}
    {{- $authors = $authors | append $author.Params.name -}}
  {{- end -}}
  {{- range .Params.contributors -}}
    {{- $author := page.GetPage (printf "/authors/%s" .author) -}}
    {{- $authors = $authors | append $author.Params.name -}}
  {{- end -}}

  {{- $topics := slice -}}
  {{- $topic_links := slice -}}
  {{- range .Params.topics -}}
    {{- $topic := page.GetPage (printf "/topics/%s" .) -}}
    {{- $topics = $topics | append $topic.Title -}}
    {{- $topic_links = $topic_links | append (printf "..%s" $topic.RelPermalink) -}}
  {{- end -}}

  {{ $related := slice }}
  {{- range .Params.related -}}
    {{- if .doi -}}
      {{- $related = $related | append (dict "doi" .doi) -}}
    {{- else -}}
      {{- $related = $related | append (dict "html" .html) -}}
    {{- end -}}
  {{- end -}}

  {{- $entry := dict
    "shortname" .Params.name
    "title" .Title
    "abstract" (.Params.abstract | replaceRE "\n" " " | plainify)
    "year" (.Date.Format "2006")
    "authors" $authors
    "topics" $topics
    "topic_links" $topic_links
    "link" (printf "..%s" .RelPermalink)
    "date" (.Date.Format "2006-01-02")
    "related" $related
    "permalink" .Permalink
  -}}

  {{- $index = $index | append $entry -}}
{{- end -}}
{{- $index | jsonify (dict "indent" " ") -}}