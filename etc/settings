# -*- shell-script -*- :mode=shellscript:

AFP_BASE="$COMPONENT"
AFP="$AFP_BASE/thys"

source "$AFP_BASE/etc/version"

if [ -z "$AFP_VERSION" ]; then
  echo 1>&2 "*** Failed to determine AFP version!"
  exit 2
fi

if [ ! "$ISABELLE_NAME" = "Isabelle$AFP_VERSION" ]; then
  if [ "$ISABELLE_NAME" = "Isabelle" ]; then
    [ ! "$AFP_VERSION" = "devel" ] && echo >&2 "### Version mismatch: Isabelle repository clone with afp-$AFP_VERSION"
  else
    echo >&2 "### Version mismatch: $ISABELLE_NAME with afp-$AFP_VERSION"
  fi
fi

isabelle_directory '$AFP_BASE'
isabelle_directory '$AFP'

AFP_BUILD_OPTIONS="browser_info document=pdf document_variants=document:outline=/proof,/ML"

ISABELLE_TOOLS="$ISABELLE_TOOLS:$AFP_BASE/tools/lib"

if [ -f "$AFP_BASE/etc/build.props" ]; then
  init_components "${ISABELLE_COMPONENTS_BASE:-$USER_HOME/.isabelle/contrib}" "$AFP_BASE/admin/components/afp"
fi
