title = AFP/Tools
module = $AFP_BASE/tools/lib/classes/afp_tools.jar
requirements = \
  env:ISABELLE_SCALA_JAR
sources = \
  tools/afp_build_ci.scala \
  tools/afp_check_metadata.scala \
  tools/afp_check_roots.scala \
  tools/afp_release.scala \
  tools/afp_site_gen.scala \
  tools/afp_stats.scala \
  tools/afp_submit.scala \
  tools/afp_structure.scala \
  tools/afp_system.scala \
  tools/afp_tools.scala \
  tools/hugo.scala \
  tools/metadata.scala \
  tools/rake.scala \
  tools/utils.scala
resources = \
  tools/SmartStoplist.txt:SmartStoplist.txt
services = \
  afp.AFP_Tools \
  afp.CI_Jobs
